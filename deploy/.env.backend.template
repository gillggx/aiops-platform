# FastAPI Backend Service — Production 環境變數
# 複製為 /opt/aiops/fastapi_backend_service/.env 並填入真實值

# ── 資料庫 ───────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://aiops:YOUR_PG_PASSWORD@localhost:5432/aiops_db"

# ── 安全 ─────────────────────────────────────────────────────────
SECRET_KEY="CHANGE_ME_RANDOM_64_CHARS"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LLM ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-XXXXXXX"
LLM_MODEL="claude-haiku-4-5-20251001"

# ── Server ───────────────────────────────────────────────────────
SERVER_BASE_URL="https://YOUR_DOMAIN"
ALLOWED_ORIGINS="https://YOUR_DOMAIN"

# ── OntologySimulator ────────────────────────────────────────────
ONTOLOGY_SIM_URL="http://localhost:8012"

# ── 內部 API Token（需與 aiops-app .env.local 一致）──────────────
INTERNAL_API_TOKEN="CHANGE_ME"

# ── 可選：Qwen / 自架 LLM ────────────────────────────────────────
# QWEN_API_KEY=""
# QWEN_BASE_URL=""
