# /opt/aiops/java-backend/.env — Java Spring Boot API
# Copy to .env on the server and fill in real secrets.

# Runtime
AIOPS_PROFILE=prod
AIOPS_JAVA_PORT=8002

# DB (Postgres; same cluster the old Python fastapi-backend points at)
DB_URL=jdbc:postgresql://localhost:5432/aiops
DB_USER=aiops
DB_PASSWORD=CHANGE_ME

# JWT (local auth fallback — 32+ chars required)
JWT_SECRET=CHANGE_ME_32_CHARS_OR_MORE_____________

# Azure AD OIDC (fill when enabling)
AUTH_MODE=local
OIDC_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Python sidecar (downstream, Java → Python)
PYTHON_SIDECAR_URL=http://127.0.0.1:8050
PYTHON_SIDECAR_TOKEN=CHANGE_ME_SIDECAR_TOKEN

# Reverse direction (Python → Java): same token both services must share
JAVA_INTERNAL_TOKEN=CHANGE_ME_INTERNAL_TOKEN
JAVA_INTERNAL_ALLOWED_IPS=127.0.0.1,::1

# CORS (Frontend origin)
CORS_ALLOWED_ORIGINS=http://localhost:8000,https://aiops.yourdomain.com
