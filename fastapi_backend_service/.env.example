DATABASE_URL="postgresql+asyncpg://<user>@localhost:5432/aiops"
# Legacy SQLite URL (deprecated — kept for local dev only):
# DATABASE_URL="sqlite+aiosqlite:///./dev.db"
SERVER_BASE_URL="http://127.0.0.1:8000"
LLM_MODEL="claude-opus-4-6"
SECRET_KEY="change-this-in-production-use-openssl-rand-hex-32"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_ORIGINS="*"
ANTHROPIC_API_KEY="sk-ant-api03-..."

# ── LangSmith tracing (Phase 2-A — optional, for agent observability) ──────
# Leave LANGSMITH_API_KEY empty to disable tracing silently.
# Get a key at https://smith.langchain.com/ (free tier: 5k runs/month)
LANGCHAIN_TRACING_V2="true"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="aiops-agent"
