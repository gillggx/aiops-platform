# ─── Upstream API ────────────────────────────────────────────────────────
# Path the Next.js /api/* proxy routes forward requests to.
#
# Phase 5d switch:
#   OLD (python FastAPI):   FASTAPI_BASE_URL=http://localhost:8001
#   NEW (java Spring Boot): FASTAPI_BASE_URL=http://localhost:8002
#
# Set this to Java once you're ready to cut Frontend traffic over. Until then,
# Java runs in "shadow mode" on :8002 with no Frontend traffic.
FASTAPI_BASE_URL=http://localhost:8001

# Same upstream used by /api/agent/* routes (LangGraph chat, Pipeline Builder
# Glass Box). Falls back to FASTAPI_BASE_URL when unset.
AGENT_BASE_URL=

# Ontology simulator (unchanged — not part of the Java migration).
ONTOLOGY_BASE_URL=http://localhost:8012

# JWT to send as Authorization: Bearer <token> on every upstream call.
# Local dev: log in once at /api/v1/auth/login then paste the access_token here.
INTERNAL_API_TOKEN=

# ─── LLM (frontend-side agent, unrelated to Java migration) ──────────────
ANTHROPIC_API_KEY=
