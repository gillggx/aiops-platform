# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
# NOTE: don't blanket-ignore `build/` — Next.js API route dirs can legitimately
# be named "build" (e.g. /api/agent/build). We only want to ignore Python
# package build outputs at the repo root.
/build/
/fastapi_backend_service/build/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite3
*_backup*
*.local_backup*
*.pre-pg-migration

# ── Migration dumps (one-shot SQLite→Postgres) ──────────────────────────
fastapi_backend_service/scripts/migration/dumps/*.jsonl

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Test / coverage ───────────────────────────────────────────────────────────
.coverage
.pytest_cache/
htmlcov/
test_outputs/

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
out/
tsconfig.tsbuildinfo

# ── Java / Gradle (java-backend/) ────────────────────────────────────────────
java-backend/.gradle/
java-backend/build/
java-backend/**/build/
!java-backend/**/src/main/**/build/
!java-backend/**/src/test/**/build/
java-backend/bin/
java-backend/out/
java-backend/.idea/
*.class

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/

# ── Playwright / E2E artifacts ────────────────────────────────────────────────
aiops-app/playwright-report/
aiops-app/test-results/
aiops-app/playwright/.cache/

# ── Local testing screenshots ────────────────────────────────────────────────
screenshots/
